#!/bin/bash
set -e

# 1. Determine Kernel Version
KVER=$(dpkg-query --show --showformat='${Version}' "$DPKG_MAINTSCRIPT_PACKAGE")

if [ -z "$KVER" ]; then
    echo "Error: Could not determine kernel version."
    exit 1
fi

# 2. Dynamically determine Root Partition Label
ROOT_LABEL=$(lsblk -no PARTLABEL $(findmnt -no SOURCE /))

if [ -z "$ROOT_LABEL" ]; then
    echo "Warning: Could not find PARTLABEL for /. Using 'linux' as fallback."
    ROOT_LABEL="linux"
fi

# 3. Format the EFI filename and command line
CLEAN_KVER="${KVER//-xiaomi-nabu-tmm/}"
OUTPUT_EFI="${CLEAN_KVER}-${ROOT_LABEL}.efi"
CMDLINE="root=PARTLABEL=$ROOT_LABEL ro fw_devlink=permissive"

BOOT_DIR="/boot"
KERNEL_IMG="$BOOT_DIR/vmlinuz-$KVER"
DTB_FILE="$BOOT_DIR/dtb-$KVER"

UKIFY_BIN=$(which ukify)

# 4. Print full details in the requested format
echo "Post-install: Generating UKI..."
echo " - Kernel:  $KERNEL_IMG"
echo " - DTB:     $DTB_FILE"
echo " - Output:  $OUTPUT_EFI"
echo " - Cmdline: $CMDLINE"

# 5. Build Unified Kernel Image (UKI)
if [ -f "$KERNEL_IMG" ] && [ -x "$UKIFY_BIN" ]; then
    # Always including DTB as requested
    "$UKIFY_BIN" build \
        --linux "$KERNEL_IMG" \
        --devicetree "$DTB_FILE" \
        --cmdline "$CMDLINE" \
        --output "$OUTPUT_EFI"
else
    echo "Error: Kernel image or ukify not found. Skipping UKI generation."
    exit 0
fi

# 6. Attempt to mount ESP and copy the file
ESP_PART="/dev/disk/by-partlabel/esp"
MNT_TMP=$(mktemp -d)
DEST_DIR="$MNT_TMP/EFI/ubuntu"
MOUNT_SUCCESS=false

if [ -b "$ESP_PART" ]; then
    for i in 1 2 3; do
        echo "Attempt $i: Mounting ESP ($ESP_PART)..."
        if mount "$ESP_PART" "$MNT_TMP" 2>/dev/null; then
            MOUNT_SUCCESS=true
            break
        fi
        sleep 1
    done
fi

if [ "$MOUNT_SUCCESS" = true ]; then
    mkdir -p "$DEST_DIR"
    cp "$OUTPUT_EFI" "$DEST_DIR/"
    echo "Success: $OUTPUT_EFI copied to ESP."
    umount "$MNT_TMP"
else
    echo "Notice: ESP not available or mount failed. Copied .efi file to /boot/"
    cp "$OUTPUT_EFI" /boot/
fi

# 7. Cleanup
rm -rf "$MNT_TMP"
rm -f "$OUTPUT_EFI"

exit 0
