#
# Extra config
#

# Reset CONFIG_LOCALVERSION
CONFIG_LOCALVERSION="-xiaomi-nabu-tmm"
CONFIG_LOCALVERSION_AUTO=n


CONFIG_ISO9660_FS=y
CONFIG_UDF_FS=y

#
# DOS/FAT/EXFAT/NT Filesystems
#
CONFIG_FAT_FS=y
# CONFIG_MSDOS_FS is not set
CONFIG_VFAT_FS=y
CONFIG_FAT_DEFAULT_CODEPAGE=437
CONFIG_FAT_DEFAULT_IOCHARSET="iso8859-1"
CONFIG_FAT_DEFAULT_UTF8=y
CONFIG_EXFAT_FS=y
CONFIG_EXFAT_DEFAULT_IOCHARSET="utf8"
CONFIG_NTFS3_FS=m
CONFIG_NTFS3_64BIT_CLUSTER=y
CONFIG_NTFS3_LZX_XPRESS=y
CONFIG_NTFS3_FS_POSIX_ACL=y
CONFIG_NTFS_FS=m

# USB audio
CONFIG_SND_USB=y
CONFIG_SND_USB_AUDIO=y

# SND_SEQ & MIDI
CONFIG_SND_SEQ_DEVICE=y
CONFIG_SND_SEQUENCER=y
CONFIG_SND_SEQ_MIDI_EVENT=y
CONFIG_SND_SEQ_MIDI=y
CONFIG_SND_SEQ_UMP=y
CONFIG_SND_RAWMIDI=y

# --- Testing serial USB terminal: Consolidated Config ---

# --- Legacy USB Serial Gadget Stack (The Core) ---
CONFIG_USB_G_SERIAL=y
CONFIG_U_SERIAL_CONSOLE=y
CONFIG_USB_U_SERIAL=y

# --- Qualcomm Hardware Drivers ---
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_QCOM=y
CONFIG_USB_QCOM_8150_PHY=y
CONFIG_SERIAL_MSM_GENI=y
CONFIG_SERIAL_MSM_GENI_CONSOLE=y

# --- Type-C and Power Management (Fixes the 13s loop) ---
CONFIG_TYPEC=n
CONFIG_TYPEC_QCOM_PMIC=n
CONFIG_USB_ROLE_SWITCH=y
CONFIG_QCOM_SPMI_ADC5=y
CONFIG_QCOM_VADC_COMMON=y

# --- Disable ConfigFS to avoid gadget conflicts ---
CONFIG_USB_CONFIGFS=n
CONFIG_USB_CONFIGFS_ACM=n
CONFIG_USB_CONFIGFS_SERIAL=n

# --- Watchdog & Reset Prevention (Nuclear Option) ---
CONFIG_WATCHDOG=y
CONFIG_WATCHDOG_CORE=n
CONFIG_QCOM_WDT=n
CONFIG_QCOM_WATCHDOG=n
CONFIG_PANIC_TIMEOUT=0

# --- Disable Remote Processors & DSPs (Fixes a4c00000 crash) ---
CONFIG_REMOTEPROC=y
CONFIG_QCOM_RPROC_COMMON=n
CONFIG_QCOM_PIL_INFO=n
CONFIG_QCOM_Q6V5_PAS=n
CONFIG_QCOM_Q6V5_ADSP=n
CONFIG_QCOM_Q6V5_CDSP=n
CONFIG_QCOM_Q6V5_MSS=n
CONFIG_QCOM_Q6V5_MPSS=n
CONFIG_QCOM_Q6V5_WCSS=n
CONFIG_QCOM_SYSMON_QMI=n

# --- Disable Graphics & Display (Avoids memory conflicts) ---
CONFIG_DRM_MSM=n
CONFIG_FB_MSM=n
CONFIG_MSM_GPU=n
CONFIG_MSM_GPU_REVMAP=n
CONFIG_QCOM_HGSL=n

# --- Disable Other High-Level Drivers ---
CONFIG_MSM_VIDC_V4L2=n
CONFIG_MSM_NPU=n
CONFIG_RPMSG_QCOM_GLINK_SMEM=n
CONFIG_QCOM_PDR_HELPERS=n

# --- Console & Debugging (Cleaned for Shell interaction) ---
CONFIG_PRINTK_TIME=y
CONFIG_CONSOLE_TRANSLATIONS=n
CONFIG_DEBUG_PREEMPT=y
CONFIG_DEBUG_BUGVERBOSE=n
CONFIG_DYNAMIC_DEBUG=n
